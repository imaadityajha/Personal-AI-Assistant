# Server
PORT=8000
NODE_ENV=production
FRONTEND_URL=https://your-frontend.vercel.app
FRONTEND_URLS=https://your-frontend.vercel.app,https://admin.yourdomain.com
ALLOW_ALL_ORIGINS=false

# Database
MONGODB_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=Cluster0

# Auth
ACCESS_TOKEN_SECRET=change-this-access-secret
REFRESH_TOKEN_SECRET=change-this-refresh-secret
ACCESS_TOKEN_EXPIRY=30d
REFRESH_TOKEN_EXPIRY=60d

# AI provider: Groq chat completions
AI_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=your-groq-api-key
AI_MODEL=llama-3.3-70b-versatile

# YouTube Data API
YOUTUBE_API_KEY=your-youtube-api-key

# Email OTP/reset
MAIL_ID=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Cloudinary avatar uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
SUPPORT_EMAIL=your-email@gmail.com
ADMIN_EMAIL=your-email@gmail.com
